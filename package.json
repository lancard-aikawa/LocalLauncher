{
  "name": "local-launcher",
  "version": "1.0.0",
  "description": "Local web server launcher with TUI dashboard",
  "scripts": {
    "start": "bun run src/index.ts",
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --compile --target=bun --outfile local-launcher.exe"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "xterm": "^5.3.0"
  }
}
